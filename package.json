{
  "name": "openpinna",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "workers:start": "tsx app/api/_lib/workers/index.ts",
    "processing:start": "tsx src/processing/index.ts",
    "processing:run-once": "tsx src/processing/index.ts --run-once",
    "processing:validate": "tsx scripts/validate-processing-repository.ts",
    "docker:up": "./scripts/docker-up.sh",
    "docker:down": "./scripts/docker-down.sh",
    "docker:reset": "./scripts/docker-down.sh -v"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/d3": "^7.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "bullmq": "^5.12.12",
    "ioredis": "^5.4.1",
    "multer": "^2.0.2",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.4",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "prettier": "^3.5.3",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
    ,
    "tsx": "^4.20.6"
  }
